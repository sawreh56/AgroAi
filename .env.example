## Local environment variables (DO NOT COMMIT REAL SECRETS)
## Prefer using `env/.env` in local dev; root `.env` is also supported.

# API
REACT_NATIVE_API_URL=http://10.0.2.2:4000

# Firebase
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_APP_ID=

# Optional integrations
GOOGLE_API_KEY=
GOOGLE_MAPS_API_KEY=
SENTRY_DSN=
STRIPE_PUBLISHABLE_KEY=
S3_BUCKET=
S3_REGION=

# App
NODE_ENV=development

# Example env file to commit to repository
# Copy to `.env` and fill with real secrets locally.

# API endpoints
REACT_NATIVE_API_URL=https://api.example.com
REACT_NATIVE_API_KEY=your_api_key_here

# Firebase (if used)
FIREBASE_API_KEY=AIzaSyExample
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=1234567890
FIREBASE_APP_ID=1:1234567890:web:abcdef123456

# Google maps
GOOGLE_MAPS_API_KEY=your_maps_key_here

# General Google API key (keep secret)
GOOGLE_API_KEY=your_google_api_key_here

# Payments
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXX

# AWS / S3
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1

# Error tracking
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Environment
NODE_ENV=production

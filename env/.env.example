## Local environment variables (DO NOT COMMIT REAL SECRETS)
## Copy this file to `env/.env` (or to project root `.env`) and fill values.
##
## This project reads values via `react-native-config` → `src/config/index.js`.

# API
REACT_NATIVE_API_URL=http://10.0.2.2:4000

# Firebase
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_APP_ID=

# Optional integrations
GOOGLE_API_KEY=
GOOGLE_MAPS_API_KEY=
SENTRY_DSN=
STRIPE_PUBLISHABLE_KEY=
S3_BUCKET=
S3_REGION=

# App
NODE_ENV=development

